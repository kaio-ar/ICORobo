package KIDVARINHA2;
import robocode.*;
import java.awt.Color;

public class DORA_AVENTURADA_2 extends AdvancedRobot {

    boolean movingForward = true;

    public void run() {
        setColors(Color.pink, Color.blue, Color.white);

        setAdjustRadarForGunTurn(true);
        setAdjustGunForRobotTurn(true);

        setTurnRadarRight(Double.POSITIVE_INFINITY);

        while (true) {
            if (movingForward) {
                setAhead(150);
            } else {
                setBack(150);
            }
            execute();
        }
    }

    public void onScannedRobot(ScannedRobotEvent e) {
        double radarTurn = getHeading() + e.getBearing() - getRadarHeading();
        setTurnRadarRight(radarTurn * 2);

        double absoluteBearing = getHeading() + e.getBearing();
        double gunTurn = absoluteBearing - getGunHeading();
        setTurnGunRight(normalizeBearing(gunTurn));

        double distance = e.getDistance();
        double firePower = Math.min(3, Math.max(1, 400 / distance));

        if (getGunHeat() == 0) {
            fire(firePower);
        }

        if (distance < 150) {
            setBack(100);
        } else {
            setAhead(100);
        }
    }

    public void onHitByBullet(HitByBulletEvent e) {
        movingForward = !movingForward;
        setTurnRight(45);
        setAhead(100);
    }

    public void onHitWall(HitWallEvent e) {
        movingForward = !movingForward;
        setBack(100);
        setTurnRight(90);
    }

    public double normalizeBearing(double angle) {
        while (angle > 180) angle -= 360;
        while (angle < -180) angle += 360;
        return angle;
    }
}
